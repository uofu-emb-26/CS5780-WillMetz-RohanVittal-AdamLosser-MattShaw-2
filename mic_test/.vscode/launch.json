{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug mic_led_meter",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/mic_led_meter.elf",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "device": "STM32F072RB",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f0x.cfg"
      ],
      "runToEntryPoint": "main",
      "gdbPath": "/usr/bin/gdb-multiarch"
    }
  ]
}